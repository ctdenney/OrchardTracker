<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Map fills remaining height; overlays sit on top -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <org.osmdroid.views.MapView
            android:id="@+id/mapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/tvNoPoints"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:padding="24dp"
            android:text="No saved points yet.\nReturn to main screen and press a tag button."
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="#CC000000"
            android:visibility="gone" />

        <!-- ── Legend overlay ─────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/legendPanel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="10dp"
            android:background="#D0000000"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:id="@+id/legendHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="LEGEND"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12" />

                <TextView
                    android:id="@+id/tvLegendArrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="▾"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/legendItems"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        <!-- ── My Location FAB ───────────────────────────────────────── -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabMyLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:contentDescription="My Location"
            android:src="@android:drawable/ic_menu_mylocation"
            app:backgroundTint="#1E1E1E"
            app:tint="@android:color/white"
            app:fabSize="normal" />

    </FrameLayout>

    <!-- Bottom action bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#1E1E1E">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExport"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Export CSV"
            android:textSize="13sp"
            android:layout_marginEnd="3dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectArea"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Select Area"
            android:textSize="13sp"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            app:backgroundTint="#37474F" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearAll"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Clear All"
            android:textSize="13sp"
            android:layout_marginStart="3dp"
            app:backgroundTint="#C62828" />

    </LinearLayout>

</LinearLayout>
