<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111111">

    <!-- ── GPS Status Bar ────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1E1E1E"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:gravity="center_vertical">

        <!-- Colored dot: red=poor, amber=ok, green=excellent -->
        <View
            android:id="@+id/viewGpsIndicator"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="@color/gps_poor" />

        <TextView
            android:id="@+id/tvGpsStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GPS: Waiting…"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:layout_marginStart="8dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvAccuracy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="±-- m"
            android:textColor="@color/gps_poor"
            android:textSize="14sp"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/tvPointCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Saved: 0 pts"
            android:textColor="#888888"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- ── Coordinate Display ─────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#181818"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp">

        <TextView
            android:id="@+id/tvLatitude"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="---.------°"
            android:textColor="#E0E0E0"
            android:textSize="18sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvLongitude"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="---.------°"
            android:textColor="#E0E0E0"
            android:textSize="18sp"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- ── Tag Buttons ────────────────────────────────────────────────── -->
    <!--
         Two-column grid fills the remaining height.
         Large text + high-contrast colours for gloved-hand / tractor use.
    -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:columnCount="2"
        android:rowCount="3"
        android:padding="8dp">

        <!-- Row 1 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="START"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:textAllCaps="false"
            android:maxLines="2"
            app:backgroundTint="@color/tag_start"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEnd"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="END"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:textAllCaps="false"
            android:maxLines="2"
            app:backgroundTint="@color/tag_end"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <!-- Row 2 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnObstacle"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="OBSTACLE"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:textAllCaps="false"
            android:maxLines="2"
            app:backgroundTint="@color/tag_obstacle"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWaypoint"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="WAYPOINT"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:textAllCaps="false"
            android:maxLines="2"
            app:backgroundTint="@color/tag_waypoint"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <!-- Row 3 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSample"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="SAMPLE"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:textAllCaps="false"
            android:maxLines="2"
            app:backgroundTint="@color/tag_sample"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMark"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="MARK"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:textAllCaps="false"
            android:maxLines="2"
            app:backgroundTint="@color/tag_mark"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

    </GridLayout>

    <!-- ── View Map ───────────────────────────────────────────────────── -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnViewMap"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_margin="8dp"
        android:text="VIEW MAP"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        app:backgroundTint="#1565C0"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

</LinearLayout>
