<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="Rename any button. Leave blank to restore its default name."
            android:textColor="#AAAAAA"
            android:textSize="14sp" />

        <!-- Slot 0 – green -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="6dp"
                android:layout_height="56dp"
                android:layout_marginEnd="12dp"
                android:background="@color/tag_start" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilLabel0"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Default: Gopher"
                app:boxStrokeColor="@color/tag_start">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etLabel0"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp" />

            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Slot 1 – red -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="6dp"
                android:layout_height="56dp"
                android:layout_marginEnd="12dp"
                android:background="@color/tag_end" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilLabel1"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Default: Blight"
                app:boxStrokeColor="@color/tag_end">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etLabel1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp" />

            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Slot 2 – orange -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="6dp"
                android:layout_height="56dp"
                android:layout_marginEnd="12dp"
                android:background="@color/tag_obstacle" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilLabel2"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Default: Blackberry"
                app:boxStrokeColor="@color/tag_obstacle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etLabel2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp" />

            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Slot 3 – blue -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="6dp"
                android:layout_height="56dp"
                android:layout_marginEnd="12dp"
                android:background="@color/tag_waypoint" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilLabel3"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Default: Broken Irrigation"
                app:boxStrokeColor="@color/tag_waypoint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etLabel3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp" />

            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Slot 4 – purple -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="6dp"
                android:layout_height="56dp"
                android:layout_marginEnd="12dp"
                android:background="@color/tag_sample" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilLabel4"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Default: Prune"
                app:boxStrokeColor="@color/tag_sample">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etLabel4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp" />

            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Slot 5 – amber -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="6dp"
                android:layout_height="56dp"
                android:layout_marginEnd="12dp"
                android:background="@color/tag_mark" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilLabel5"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Default: End Tank"
                app:boxStrokeColor="@color/tag_mark">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etLabel5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp" />

            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Actions -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveLabels"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:text="Save Labels"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#1565C0" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnResetDefaults"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Reset to Defaults"
            android:textSize="14sp"
            app:strokeColor="#555555" />

    </LinearLayout>
</ScrollView>
